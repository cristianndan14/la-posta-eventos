---
import '../index.css';
import { faqs } from '../data/faqs';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'La Posta Eventos | Catering de Parrilla, Sushi y Milanesas en CABA',
  description = 'Catering en CABA y zona sur: parrilla a domicilio, sushi y sushi burger, sanguches de milanesa y empanadas tucumanas para eventos. Pedí tu presupuesto hoy.',
} = Astro.props;

const areasServed = ['Buenos Aires', 'CABA', 'Monte Grande', '9 de Abril', 'Esteban Echeverría', 'Zona Sur GBA'];

const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'FoodEstablishment',
      name: 'La Posta Eventos',
      description:
        'Catering para eventos en CABA y zona sur del Gran Buenos Aires: parrilla, sushi y sushi burger, sanguches de milanesa tucumana y empanadas tucumanas.',
      url: 'https://lapostacatering.com.ar',
      telephone: '+54-11-2163-9741',
      email: 'hola@laposta.com.ar',
      servesCuisine: ['Argentine', 'Sushi', 'Japanese'],
      priceRange: '$$',
      address: {
        '@type': 'PostalAddress',
        addressLocality: 'Buenos Aires',
        addressRegion: 'CABA',
        addressCountry: 'AR',
      },
      areaServed: areasServed.map((name) => ({ '@type': 'Place', name })),
      hasMenu: {
        '@type': 'Menu',
        hasMenuSection: [
          { '@type': 'MenuSection', name: 'Parrilla', description: 'Asado completo con parrillero profesional.' },
          { '@type': 'MenuSection', name: 'Empanadas Tucumanas', description: 'Hechas a mano, receta del norte argentino.' },
          { '@type': 'MenuSection', name: 'Sushi & Sushi Burger', description: 'Rolls, combinados y sushi burger de autor.' },
          { '@type': 'MenuSection', name: 'Sanguches de Milanesa Tucumana', description: 'Milanesas gigantes en pan casero.' },
        ],
      },
    },
    {
      '@type': 'FAQPage',
      mainEntity: faqs.map((faq) => ({
        '@type': 'Question',
        name: faq.q,
        acceptedAnswer: { '@type': 'Answer', text: faq.a },
      })),
    },
  ],
};
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="author" content="La Posta Eventos" />
    <link rel="canonical" href="https://lapostacatering.com.ar" />

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:image" content="https://lapostacatering.com.ar/favicon.jpg" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="@LaPostaCatering" />
    <meta name="twitter:image" content="https://lapostacatering.com.ar/favicon.jpg" />

    <link rel="icon" href="/favicon.jpg" type="image/jpeg" />

    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </head>
  <body>
    <slot />
  </body>
</html>
