---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Página no encontrada | La Posta Eventos" description="La página que buscás no existe.">
  <main class="min-h-screen flex items-center justify-center bg-background text-center px-4">
    <div>
      <h1 class="font-display text-8xl font-bold text-primary mb-4">404</h1>
      <p class="font-body text-xl text-muted-foreground mb-8 normal-case">
        Esta página no existe o fue movida.
      </p>
      <a
        href="/"
        class="inline-block bg-primary text-primary-foreground font-semibold px-8 py-3 rounded-full uppercase tracking-wide hover:bg-brand-glow transition-colors"
      >
        Volver al inicio
      </a>
    </div>
  </main>
</Layout>
